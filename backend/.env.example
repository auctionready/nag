# Local development overrides for `dotnet run --project Nag.Api`.
#
# Copy to `.env.local` (gitignored) and edit. dotenv.net loads both
# `.env` and `.env.local` in Debug builds (see Program.cs); .NET
# config uses `__` (double underscore) to separate JSON sections,
# e.g. `Nag__DeviceToken__Secret` → `Nag:DeviceToken:Secret`.

# HMAC-SHA256 signing key for per-device bearer tokens. Generate with:
#   openssl rand -base64 48
# Rotating invalidates every previously-issued device token, so on the
# next request mobile clients hit 401 and re-register.
Nag__DeviceToken__Secret=

# Optional. Clerk Frontend API URL for JWT verification. Leave unset to
# disable Clerk-mode entirely (the auth handler will 401 any JWT-shaped
# bearer). Mobile-only deployments don't need this.
# Nag__ClerkIssuer=https://your-instance.clerk.accounts.dev

# Optional. Postgres connection string override; otherwise the value in
# appsettings.json is used (assumes `docker compose up -d` from this dir).
# ConnectionStrings__Nag=Host=localhost;Port=5432;Database=nag;Username=postgres;Password=postgres
