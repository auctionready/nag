{
  "name": "@nag/backend",
  "private": true,
  "scripts": {
    "format": "dotnet csharpier format .",
    "test": "dotnet test",
    "build": "dotnet build",
    "openapi": "./scripts/generate-openapi.sh",
    "package:lambda": "./scripts/package-lambda.sh",
    "package:lambda:run": "./scripts/run-lambda-locally.sh",
    "check": "concurrently -g \"pnpm check:format\" \"pnpm check:openapi\"",
    "check:format": "dotnet csharpier check .",
    "check:openapi": "pnpm --filter @nag/api-client generate && git diff --exit-code ../packages/api-client/src/endpoint-definition.ts"
  },
  "devDependencies": {
    "concurrently": "catalog:"
  },
  "volta": {
    "extends": "../package.json"
  }
}
