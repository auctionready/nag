# Copy to ~/.config/nag/expo.env on the VPS and adjust. Loaded by
# nag-expo.service.

# REQUIRED. Tell Metro which hostname to advertise in the manifest it
# returns to the dev client. Without this, the manifest contains URLs
# pointing at `localhost:8081` and the device can't reach them. Set it
# to the hostname your reverse proxy (nginx / Caddy) serves.
REACT_NATIVE_PACKAGER_HOSTNAME=dev.example.com

# might speed things up
EXPO_USE_FAST_RESOLVER=1

# Do NOT set CI=1 here. It puts Metro in non-watch mode, which means
# the bundler cache never warms up and every request re-transforms
# everything from scratch. The startup prompts are harmless.
