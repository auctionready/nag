# Copy to ~/.config/nag/expo.env on the VPS and adjust. Loaded by
# nag-expo.service.

# Tell Metro which hostname to advertise in URLs it prints. Set this to the
# public hostname Caddy serves so the dev client sees the right URL.
REACT_NATIVE_PACKAGER_HOSTNAME=dev.example.com

# Optional: quiet the Expo CLI "open on iOS/Android" prompts in logs.
CI=1
