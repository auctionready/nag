{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": [
    "tsconfig.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml"
  ],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"],
      "outputs": []
    },
    "@nag/app#typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "__mocks__/**",
        "modules/**",
        "*.ts",
        "*.tsx",
        "*.config.ts",
        "*.config.js",
        ".expo/types/**",
        "expo-env.d.ts",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "vitest.config.*",
        "vitest.setup.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "@nag/app#test": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "__mocks__/**",
        "jest.config.*",
        "jest.setup.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "@nag/app#check:circular": {
      "inputs": ["src/**/*.{ts,tsx}", "package.json"],
      "outputs": []
    },
    "//#lint": {
      "inputs": [
        "app/**/*.{ts,tsx,js,jsx,cjs,mjs}",
        "packages/*/src/**/*.{ts,tsx,js,jsx,cjs,mjs}",
        "packages/*/*.{ts,js,cjs,mjs}",
        "eslint.config.*",
        ".eslintrc*",
        "*.config.{ts,js,cjs,mjs}",
        "package.json"
      ],
      "outputs": [".eslintcache"]
    },
    "//#format:check:app": {
      "inputs": [
        "app/**/*.{ts,tsx,js,jsx,json,md,yml,yaml}",
        "packages/**/*.{ts,tsx,js,jsx,json,md,yml,yaml}",
        "*.{ts,tsx,js,jsx,json,md,yml,yaml}",
        ".prettierrc*",
        ".prettierignore",
        "package.json"
      ],
      "outputs": ["node_modules/.cache/prettier/**"]
    }
  }
}
