{
  "name": "nag",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "tsc -b --clean",
    "dev": "pnpm typecheck && pnpm lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "concurrently -g \"pnpm format:app\" \"pnpm format:backend\"",
    "format:app": "prettier --write .",
    "format:check": "concurrently -g \"pnpm format:check:app\" \"pnpm format:check:backend\"",
    "format:check:app": "prettier --check .",
    "format:check:backend": "pnpm --filter @nag/backend check:format",
    "format:backend": "pnpm --filter @nag/backend format",
    "test": "pnpm test:app && pnpm test:backend",
    "test:app": "pnpm -r --filter !@nag/backend --filter !nag run test",
    "test:backend": "pnpm --filter @nag/backend test",
    "check:app": "concurrently -g \"pnpm typecheck\" \"pnpm lint\" \"pnpm test:app\" \"pnpm format:check:app\"",
    "check:backend": "pnpm --filter @nag/backend check",
    "check": "pnpm check:backend && pnpm check:app",
    "typecheck": "tsc -b",
    "typecheck:watch": "tsc -b --watch",
    "prepare": "lefthook install"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "better-sqlite3",
      "lefthook"
    ],
    "patchedDependencies": {
      "@expo/dom-webview@55.0.3": "patches/@expo__dom-webview@55.0.3.patch"
    }
  },
  "packageManager": "pnpm@10.33.2",
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.2"
  },
  "devDependencies": {
    "concurrently": "catalog:",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript": "catalog:"
  }
}
