{
  "name": "nag",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "tsc -b --clean",
    "dev": "pnpm typecheck && pnpm lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test",
    "check": "concurrently -g \"pnpm typecheck\" \"pnpm lint\" \"pnpm test\"",
    "typecheck": "tsc -b",
    "typecheck:watch": "tsc -b --watch",
    "prepare": "lefthook install"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "lefthook"
    ],
    "patchedDependencies": {
      "@expo/dom-webview@55.0.3": "patches/@expo__dom-webview@55.0.3.patch"
    }
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3"
  }
}
