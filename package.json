{
  "name": "nag",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm typecheck && pnpm lint",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix",
    "format": "concurrently -g \"pnpm format:app\" \"pnpm format:backend\"",
    "format:app": "prettier --write .",
    "format:check": "concurrently -g \"pnpm format:check:app\" \"pnpm format:check:backend\"",
    "format:check:app": "prettier --check . --cache --cache-location node_modules/.cache/prettier/check",
    "format:check:backend": "pnpm --filter @nag/backend check:format",
    "format:backend": "pnpm --filter @nag/backend format",
    "test": "pnpm test:app && pnpm test:backend",
    "test:app": "turbo run test --filter=!@nag/backend",
    "test:backend": "turbo run test --filter=@nag/backend",
    "check:app": "turbo run typecheck test check:circular //#lint //#format:check:app --filter=!@nag/backend",
    "check:backend": "turbo run check:format --filter=@nag/backend && turbo run //#check:openapi",
    "check:openapi": "pnpm --filter @nag/backend check:openapi",
    "check": "pnpm check:backend && pnpm check:app",
    "deploy:backend": "pnpm --filter @nag/backend run deploy",
    "typecheck": "turbo run typecheck",
    "prepare": "lefthook install --force",
    "postinstall": "node tools/check-dotnet-version.mjs"
  },
  "packageManager": "pnpm@11.2.2",
  "devDependencies": {
    "concurrently": "catalog:",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  }
}
