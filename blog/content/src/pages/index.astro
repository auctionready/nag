---
import Base from "../layouts/Base.astro";
---

<Base
  title="nag. — habit enforcement, with a smirk"
  description="A habit app that follows up. Set a cadence. Get nudged. See compliance. Nag is the friend who actually keeps you to it."
  current="home"
>
  <!-- ──────── Hero ──────── -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="kicker">v1.0 · out now</div>
        <h1 class="h-display" style="margin: 18px 0 0;">
          still<br />waiting<span class="dot">.</span>
        </h1>
        <p class="lede" style="margin-top: 28px;">
          nag is a habit app that follows up. Set a goal, pick a cadence,
          get a little pestering until you do the thing. Then it shuts up.
        </p>

        <div class="hero-cta-row">
          <a href="#get" class="btn btn-primary">Get nag<span class="arrow">→</span></a>
          <a href="/how-it-works" class="btn btn-ghost">See how it works</a>
        </div>

        <div class="hero-meta">
          <span><b>iOS</b> · 17+</span>
          <span><b>Android</b> · 11+</span>
          <span><b>$0</b> · no account</span>
        </div>
      </div>

      <!-- phone mock -->
      <div>
        <div class="phone" aria-hidden="true">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="phone-status">
              <span>9:41</span>
              <span>· · ·</span>
            </div>
            <div class="mock-home">
              <div class="mock-home-hd">
                <div class="title">today<span class="dot">.</span></div>
                <div class="date">tue · 22 may</div>
              </div>
              <div class="mock-grid">
                <div class="mock-tile tile-orange">
                  <div>
                    <div class="t-meta">daily · streak ×12</div>
                    <div class="t-name" style="margin-top: 6px;">read 20 min</div>
                  </div>
                  <div class="t-foot">
                    <div class="mock-week" aria-hidden="true">
                      <div class="cell done"></div><div class="cell done"></div><div class="cell done"></div>
                      <div class="cell today"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
                    </div>
                    <div class="tile-streak">12<span style="font-size: 14px; opacity:.7">d</span></div>
                  </div>
                </div>

                <div class="mock-tile">
                  <div>
                    <div class="t-meta">3× · weekly</div>
                    <div class="t-name" style="margin-top: 6px;">gym</div>
                  </div>
                  <div class="t-foot">
                    <div class="mock-week" aria-hidden="true">
                      <div class="cell done"></div><div class="cell"></div><div class="cell done"></div>
                      <div class="cell today"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
                    </div>
                    <div class="tile-streak" style="color: var(--nag-orange)">2/3</div>
                  </div>
                </div>

                <div class="mock-tile tile-ink">
                  <div>
                    <div class="t-meta">m / w / f</div>
                    <div class="t-name" style="margin-top: 6px;">call mum</div>
                  </div>
                  <div class="t-foot">
                    <div class="mock-week" aria-hidden="true">
                      <div class="cell done"></div><div class="cell"></div><div class="cell miss"></div>
                      <div class="cell today"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
                    </div>
                    <div class="tile-streak" style="font-size: 22px;">↻</div>
                  </div>
                </div>

                <div class="mock-tile">
                  <div>
                    <div class="t-meta">monthly · once</div>
                    <div class="t-name" style="margin-top: 6px;">backup laptop</div>
                  </div>
                  <div class="t-foot">
                    <div class="mock-week" aria-hidden="true">
                      <div class="cell"></div><div class="cell"></div><div class="cell"></div>
                      <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell today"></div>
                    </div>
                    <div class="tile-streak" style="font-size: 18px; color: var(--nag-mute)">0/1</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────── Taunt marquee ──────── -->
  <div class="taunt-strip" aria-hidden="true">
    <div class="taunt-track">
      <span>ok do it.<span class="sep">·</span></span>
      <span>still waiting.<span class="sep">·</span></span>
      <span>today. yes today.<span class="sep">·</span></span>
      <span>no excuses.<span class="sep">·</span></span>
      <span>tick tick tick.<span class="sep">·</span></span>
      <span>ok do it.<span class="sep">·</span></span>
      <span>still waiting.<span class="sep">·</span></span>
      <span>today. yes today.<span class="sep">·</span></span>
      <span>no excuses.<span class="sep">·</span></span>
      <span>tick tick tick.<span class="sep">·</span></span>
    </div>
  </div>

  <!-- ──────── What it is ──────── -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">What it does</span>
        <h2 class="h-1">Three things, well<span class="dot">.</span></h2>
        <p class="lede">No streak shaming, no points, no AI coach. Just cadence, follow-up, and a record so honest it stings a little.</p>
      </div>

      <div class="feat-grid">
        <div class="feat">
          <div class="feat-icon orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
              <circle cx="6" cy="12" r="2" /><circle cx="12" cy="12" r="2" /><circle cx="18" cy="12" r="2" />
            </svg>
          </div>
          <h3>Cadence, your way</h3>
          <p>Daily, X times a week, specific weekdays, monthly, or one-off. Nag handles the math so you don't track it in your head.</p>
          <div class="cadence-row" style="margin-top: 6px;">
            <div class="cad-dot"></div><div class="cad-dot"></div><div class="cad-dot"></div>
            <div class="cad-dot miss"></div><div class="cad-dot today"></div>
            <div class="cad-dot future"></div><div class="cad-dot future"></div>
          </div>
        </div>

        <div class="feat">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 1 1-3-6.7" />
              <path d="M21 4v5h-5" />
            </svg>
          </div>
          <h3>Follow-up that follows up</h3>
          <p>Miss your slot? Nag pings — gently, then less gently. Reschedule, skip, or commit. Notifications you'll actually act on.</p>
        </div>

        <div class="feat">
          <div class="feat-icon orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l4 4 10-10" />
            </svg>
          </div>
          <h3>An honest record</h3>
          <p>See your real compliance, week by week, month by month. Not a streak — a track record. The truth, in dots.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────── Big quote / pitch ──────── -->
  <section style="padding-top: 0;">
    <div class="wrap">
      <div style="display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1.2fr); gap: clamp(32px, 6vw, 96px); align-items: center;">
        <div>
          <span class="kicker">Why nag</span>
          <h2 class="h-1" style="margin-top: 12px;">Habit apps are too nice<span class="dot">.</span></h2>
        </div>
        <div>
          <p class="body-lg">
            Streaks reward perfect runs and quietly punish the rest. Coaches over-explain.
            Most apps celebrate you logging in. Nag does the opposite — it gets out of your way
            when you're on it, and gets in your face when you're not.
          </p>
          <p class="body-lg" style="margin-top: 14px;">
            It's the friend who texts <em>"did you?"</em> at 9pm. Annoying, but you did it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────── Get the app CTA ──────── -->
  <section id="get" style="padding-top: 0;">
    <div class="wrap">
      <div class="cta-band">
        <h2>
          ok<span class="dot" style="color: var(--nag-ink)">.</span><br />
          do it<span class="dot" style="color: var(--nag-ink)">.</span>
        </h2>
        <div class="right">
          <p>Free · iOS &amp; Android · No account required</p>
          <div class="cta-row">
            <a href="#" class="btn btn-ink">↓ App Store</a>
            <a href="#" class="btn btn-ink">↓ Google Play</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
