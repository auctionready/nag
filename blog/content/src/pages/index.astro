---
import Base from "../layouts/Base.astro";
---

<Base
  title="nag. — habit embedding, with a smirk"
  description="A habit app that follows up. Set a cadence. Get nudged. See compliance. Nag is the friend who actually keeps you to it."
  current="home"
>
  <!-- ──────── Hero ──────── -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="kicker">v1.0 · out now</div>
        <h1 class="h-display" style="margin: 18px 0 0;">
          still<br />waiting<span class="dot">.</span>
        </h1>
        <p class="lede" style="margin-top: 28px;">
          nag is a habit app that follows up. Set a goal, pick a cadence, get a
          little pestering until you do the thing. Then it shuts up.
        </p>

        <div class="hero-cta-row">
          <a href="#get" class="btn btn-primary"
            >Get nag<span class="arrow">→</span></a
          >
          <a href="/how-it-works" class="btn btn-ghost">See how it works</a>
        </div>

        <div class="hero-meta">
          <span><b>iOS</b> · 17+</span>
          <span><b>$0</b> · no account</span>
        </div>
      </div>

      <!-- phone mock — Nag Variant A home board -->
      <div>
        <div class="phone" aria-hidden="true">
          <div class="phone-notch"></div>
          <div class="phone-home-indicator"></div>
          <div class="phone-screen">
            <div class="phone-status">
              <span>9:41</span>
              <span class="signal">
                <span class="bars"
                  ><span></span><span></span><span></span><span></span></span
                >
                <span class="battery"><span class="fill"></span></span>
              </span>
            </div>

            <div class="mock-home">
              <!-- Top bar -->
              <div class="mock-topbar">
                <div class="mock-avatar">JC</div>
                <div class="center">
                  <div class="wm">nag<span class="dot">.</span></div>
                  <div class="sync"><span class="led"></span> synced</div>
                </div>
                <div class="mock-iconbtn">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3" y="5" width="18" height="16" rx="2"></rect>
                    <path d="M3 10h18M8 3v4M16 3v4"></path>
                  </svg>
                </div>
              </div>

              <!-- Header -->
              <div class="mock-hd">
                <div class="pct">60<span class="unit">% today</span></div>
                <div class="line">3 of 5 done. one to go.</div>
              </div>

              <!-- Grid -->
              <div class="mock-grid">
                <!-- Tile 1: read 20 min, daily -->
                <div class="mock-tile">
                  <div class="t-top">
                    <div class="t-icon">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M4 5a2 2 0 0 1 2-2h5v17H6a2 2 0 0 1-2-2V5z"
                        ></path>
                        <path d="M20 5a2 2 0 0 0-2-2h-5v17h5a2 2 0 0 0 2-2V5z"
                        ></path>
                      </svg>
                    </div>
                    <div class="t-cad">daily</div>
                  </div>
                  <div class="t-name">read 20 min</div>
                  <div class="t-last">2h ago</div>
                  <div class="t-spacer"></div>
                  <div class="mock-week">
                    <div class="col">
                      <span class="lbl">M</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">T</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">W</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl is-today">T</span>
                      <div class="cell today-done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">F</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                  </div>
                </div>

                <!-- Tile 2: water, 3× today -->
                <div class="mock-tile">
                  <div class="t-top">
                    <div class="t-icon">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M12 3s6 7 6 12a6 6 0 0 1-12 0c0-5 6-12 6-12z"
                        ></path>
                      </svg>
                    </div>
                    <div class="t-cad-dots">
                      <span class="today-pre">TODAY</span>
                      <span class="sd done"></span>
                      <span class="sd done"></span>
                      <span class="sd pending"></span>
                    </div>
                  </div>
                  <div class="t-name">drink water</div>
                  <div class="t-last">3h ago</div>
                  <div class="t-spacer"></div>
                  <div class="mock-week">
                    <div class="col">
                      <span class="lbl">M</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">T</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">W</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl is-today">T</span>
                      <div class="cell today"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">F</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                  </div>
                </div>

                <!-- Tile 3: gym, M/W/F -->
                <div class="mock-tile">
                  <div class="t-top">
                    <div class="t-icon">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M6 6v12M18 6v12M3 9v6M21 9v6M6 12h12"></path>
                      </svg>
                    </div>
                    <div class="t-cad">m·w·f</div>
                  </div>
                  <div class="t-name">gym</div>
                  <div class="t-last">yesterday</div>
                  <div class="t-spacer"></div>
                  <div class="mock-week">
                    <div class="col">
                      <span class="lbl">M</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">T</span>
                      <div class="cell skip"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">W</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl is-today">T</span>
                      <div class="cell skip"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">F</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell skip"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell skip"></div>
                    </div>
                  </div>
                </div>

                <!-- Tile 4: call mum, weekly -->
                <div class="mock-tile">
                  <div class="t-top">
                    <div class="t-icon">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path
                          d="M5 4h3l2 5-2 1a11 11 0 0 0 6 6l1-2 5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"
                        ></path>
                      </svg>
                    </div>
                    <div class="t-cad-dots">
                      <span class="sd done"></span>
                      <span class="sd behind"></span>
                    </div>
                  </div>
                  <div class="t-name">call mum</div>
                  <div class="t-last">sat</div>
                  <div class="t-spacer"></div>
                  <div class="mock-week">
                    <div class="col">
                      <span class="lbl">M</span>
                      <div class="cell skip"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">T</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">W</span>
                      <div class="cell skip"></div>
                    </div>
                    <div class="col">
                      <span class="lbl is-today">T</span>
                      <div class="cell today"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">F</span>
                      <div class="cell skip"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell skip"></div>
                    </div>
                  </div>
                </div>

                <!-- Tile 5: meditate, daily -->
                <div class="mock-tile">
                  <div class="t-top">
                    <div class="t-icon">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <circle cx="12" cy="12" r="9"></circle>
                        <path d="M12 3v18M3 12h18"></path>
                      </svg>
                    </div>
                    <div class="t-cad">daily</div>
                  </div>
                  <div class="t-name">meditate</div>
                  <div class="t-last">missed</div>
                  <div class="t-spacer"></div>
                  <div class="mock-week">
                    <div class="col">
                      <span class="lbl">M</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">T</span>
                      <div class="cell missed"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">W</span>
                      <div class="cell done"></div>
                    </div>
                    <div class="col">
                      <span class="lbl is-today">T</span>
                      <div class="cell today"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">F</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                    <div class="col">
                      <span class="lbl">S</span>
                      <div class="cell future"></div>
                    </div>
                  </div>
                </div>

                <!-- Add tile -->
                <div class="mock-tile add">
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
                    <path
                      d="M7 2v10M2 7h10"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"></path>
                  </svg>
                  add habit
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────── Taunt marquee ──────── -->
  <div class="taunt-strip" aria-hidden="true">
    <div class="taunt-track">
      <span>ok do it.<span class="sep">·</span></span>
      <span>still waiting.<span class="sep">·</span></span>
      <span>today. yes today.<span class="sep">·</span></span>
      <span>no excuses.<span class="sep">·</span></span>
      <span>tick tick tick.<span class="sep">·</span></span>
      <!-- duplicate for seamless loop -->
      <span>ok do it.<span class="sep">·</span></span>
      <span>still waiting.<span class="sep">·</span></span>
      <span>today. yes today.<span class="sep">·</span></span>
      <span>no excuses.<span class="sep">·</span></span>
      <span>tick tick tick.<span class="sep">·</span></span>
    </div>
  </div>

  <!-- ──────── What it is ──────── -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">What it does</span>
        <h2 class="h-1">Three things, well<span class="dot">.</span></h2>
        <p class="lede">
          No streaks, no points, no AI coach. Just cadence, follow-up, and a
          record so honest it stings a little.
        </p>
      </div>

      <div class="feat-grid">
        <div class="feat">
          <div class="feat-icon orange">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
            >
              <circle cx="6" cy="12" r="2"></circle>
              <circle cx="12" cy="12" r="2"></circle>
              <circle cx="18" cy="12" r="2"></circle>
            </svg>
          </div>
          <h3>Cadence, your way</h3>
          <p>
            Daily, X times a week, specific weekdays, monthly, or one-off. Nag
            handles the math so you don't track it in your head.
          </p>
          <div class="cadence-row" style="margin-top: 6px;">
            <div class="cad-dot"></div>
            <div class="cad-dot"></div>
            <div class="cad-dot"></div>
            <div class="cad-dot miss"></div>
            <div class="cad-dot today"></div>
            <div class="cad-dot future"></div>
            <div class="cad-dot future"></div>
          </div>
        </div>

        <div class="feat">
          <div class="feat-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12a9 9 0 1 1-3-6.7"></path>
              <path d="M21 4v5h-5"></path>
            </svg>
          </div>
          <h3>Follow-up that follows up</h3>
          <p>
            Miss your slot? Nag pings — gently, then less gently. Reschedule,
            skip, or commit. Notifications you'll actually act on.
          </p>
        </div>

        <div class="feat">
          <div class="feat-icon orange">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12l4 4 10-10"></path>
            </svg>
          </div>
          <h3>An honest record</h3>
          <p>
            See your real compliance, week by week, month by month. No streaks
            to break — just a track record. The truth, in dots.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────── Big quote / pitch ──────── -->
  <section style="padding-top: 0;">
    <div class="wrap">
      <div
        style="display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1.2fr); gap: clamp(32px, 6vw, 96px); align-items: center;"
      >
        <div>
          <span class="kicker">Why nag</span>
          <h2 class="h-1" style="margin-top: 12px;">
            Habit apps are too nice<span class="dot">.</span>
          </h2>
        </div>
        <div>
          <p class="body-lg">
            Streaks reward perfect runs and quietly punish the rest. Coaches
            over-explain. Most apps celebrate you logging in. Nag does none of
            that. It gets out of your way when you're on it, and gets in your
            face when you're not — until the habit's embedded, then it fades
            into routine.
          </p>
          <p class="body-lg" style="margin-top: 14px;">
            It's the friend who texts <em>"did you?"</em> at 9pm. Annoying, but you
            did it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────── Get the app CTA ──────── -->
  <section id="get" style="padding-top: 0;">
    <div class="wrap">
      <div class="cta-band">
        <h2>
          ok<span class="dot" style="color: var(--nag-ink)">.</span><br />
          do it<span class="dot" style="color: var(--nag-ink)">.</span>
        </h2>
        <div class="right">
          <p>Free · iOS · No account required</p>
          <div class="cta-row">
            <a href="#" class="btn btn-ink">↓ App Store</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
