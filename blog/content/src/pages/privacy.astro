---
import Base from "../layouts/Base.astro";

// Last updated — bump this whenever the policy text changes.
const updated = "27 June 2026";
---

<Base
  title="Privacy — nag."
  description="nag keeps your habits on your device. No account, no cloud, no tracking. The only data that leaves your phone is anonymous diagnostics (crash, performance, and technical logs)."
>
  <!-- ──────── Page header ──────── -->
  <section class="section-sm section-pt-lg">
    <div class="wrap">
      <div class="kicker">Privacy</div>
      <h1 class="h-display" style="margin-top: 18px;">
        your habits stay<br />
        on your phone<span class="dot">.</span>
      </h1>
      <p class="lede" style="margin-top: 28px;">
        No account, no cloud, nothing to sell. Your data stays on your device.
        The only thing that leaves is anonymous diagnostics — and that's the
        whole story.
      </p>
    </div>
  </section>

  <!-- ──────── Policy body ──────── -->
  <section class="section-pt-0" style="padding-bottom: 96px;">
    <div class="wrap">
      <div class="prose">
        <p><em>Last updated: {updated}</em></p>

        <h2>On your device</h2>
        <p>
          Your habits, check-ins, schedules, and reminders live only on your
          iPhone, in a private database. They are never sent to us or anyone
          else, and deleting the app deletes them — we keep no copy.
        </p>

        <h2>Diagnostics</h2>
        <p>
          The one thing that leaves your phone is anonymous diagnostics, sent
          via <a href="https://sentry.io/" rel="noopener">Sentry</a> to keep nag stable
          and fast. Some is sent during normal use, not only on crashes:
        </p>
        <ul>
          <li>
            performance and timing data, and technical logs (e.g. "a screen
            opened");
          </li>
          <li>
            on a crash, the error and stack trace, plus a screen replay with all
            text and images masked;
          </li>
          <li>your device model, OS version, and app version.</li>
        </ul>
        <p>
          None of it includes your habits, check-ins, notes, or any personal
          information, and it is never used to identify you or track you across
          apps.
        </p>

        <h2>Notifications</h2>
        <p>
          Reminders are local notifications scheduled on your device. nag uses
          no remote push and sends no notification data anywhere.
        </p>

        <h2>What nag never does</h2>
        <ul>
          <li>No accounts, ads, or advertising identifiers.</li>
          <li>
            No product analytics, behavioural profiling, or cross-app tracking.
          </li>
          <li>No selling or sharing of data.</li>
          <li>
            No access to your location, contacts, photos, microphone, or camera.
          </li>
        </ul>

        <h2>Contact</h2>
        <p>
          nag collects no personal information from anyone, children included.
          If this policy changes, the date above changes too. Questions? Email
          <a href="mailto:privacy@auctionready.co.nz"
            >privacy@auctionready.co.nz</a
          >.
        </p>
      </div>
    </div>
  </section>
</Base>
