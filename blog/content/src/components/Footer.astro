---
import BrandMark from "./BrandMark.astro";
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand">
          <BrandMark />
          <span class="brand-wm">nag<span class="dot">.</span></span>
        </a>
        <p class="blurb">
          A habit-embedding app that follows up. Made by one person in a small
          house, probably nagging themselves about something right now.
        </p>
      </div>
      <div>
        <h4>Product</h4>
        <ul>
          <li><a href="/how-it-works">How it works</a></li>
          <li><a href="/#get">Download</a></li>
        </ul>
      </div>
      <div>
        <h4>Read</h4>
        <ul>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/blog">Release notes</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bot">
      <span
        >© 2026 nag<span class="dot">.</span> · made in NZ ·
        <a href="/privacy">Privacy</a></span
      >
      <span>still waiting.</span>
    </div>
    <div class="wm">
      nag<span class="dot" style="color: var(--nag-orange); opacity: 1;">.</span
      >
    </div>
  </div>
</footer>
