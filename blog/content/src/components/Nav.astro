---
import BrandMark from "./BrandMark.astro";

type NavKey = "home" | "how-it-works" | "blog";

interface Props {
  current?: NavKey;
}

const { current } = Astro.props;
const isActive = (key: NavKey) => (current === key ? "is-active" : undefined);
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="nag home">
      <BrandMark />
      <span class="brand-wm">nag<span class="dot">.</span></span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/" class={isActive("home")}>Home</a>
      <a href="/how-it-works" class={isActive("how-it-works")}>How it works</a>
      <a href="/blog" class={isActive("blog")}>Blog</a>
    </nav>
    <a href="/#get" class="nav-cta"><span class="dot"></span> Get the app</a>
  </div>
</header>
