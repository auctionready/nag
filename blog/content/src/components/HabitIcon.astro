---
// Inline-SVG icon used inside a mock tile's `.t-icon` slot.
// All icons are 14×14, stroke 1.7, currentColor — so they inherit the
// surrounding tile's text colour.
//
// To add an icon: pick a name and append a case to the switch below.
type IconName =
  | "book"
  | "water"
  | "gym"
  | "phone"
  | "meditate"
  | "calendar"
  | "clock";

interface Props {
  name: IconName;
}
const { name } = Astro.props;
---

<svg
  width="14"
  height="14"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  {
    name === "book" && (
      <>
        <path d="M4 5a2 2 0 0 1 2-2h5v17H6a2 2 0 0 1-2-2V5z" />
        <path d="M20 5a2 2 0 0 0-2-2h-5v17h5a2 2 0 0 0 2-2V5z" />
      </>
    )
  }
  {
    name === "water" && (
      <path d="M12 3s6 7 6 12a6 6 0 0 1-12 0c0-5 6-12 6-12z" />
    )
  }
  {name === "gym" && <path d="M6 6v12M18 6v12M3 9v6M21 9v6M6 12h12" />}
  {
    name === "phone" && (
      <path d="M5 4h3l2 5-2 1a11 11 0 0 0 6 6l1-2 5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z" />
    )
  }
  {
    name === "meditate" && (
      <>
        <circle cx="12" cy="12" r="9" />
        <path d="M12 3v18M3 12h18" />
      </>
    )
  }
  {
    name === "calendar" && (
      <>
        <rect x="3" y="5" width="18" height="16" rx="2" />
        <path d="M3 10h18M8 3v4M16 3v4" />
      </>
    )
  }
  {
    name === "clock" && (
      <>
        <circle cx="12" cy="12" r="9" />
        <path d="M12 7v5l3 2" />
      </>
    )
  }
</svg>
