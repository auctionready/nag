{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_SIGNIN_PROVIDERS": "email,apple,google,phone",
        "SENTRY_ALLOW_FAILURE": "true"
      },
      "node": "24.14.1"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_SIGNIN_PROVIDERS": "email,apple,google,phone",
        "SENTRY_ALLOW_FAILURE": "true"
      },
      "node": "24.14.1"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_SIGNIN_PROVIDERS": "email",
        "SENTRY_ALLOW_FAILURE": "true"
      },
      "node": "24.14.1"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "alan@christensen.org.nz",
        "ascAppId": "6771661951"
      }
    }
  }
}
