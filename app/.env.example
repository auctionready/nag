# App env config. Metro reads `.env` at start; `app.config.ts` forwards
# selected vars into `Constants.expoConfig.extra`. `.env.local`
# (gitignored) overrides any value here. Both `.env` and `.env.local`
# in this folder are gitignored — copy this example to `.env` to
# bootstrap.
#
# Two named modes — pick one or use the dev menu's "Switch backend…"
# item to flip at runtime (writes a SecureStore override that wins
# over these env values until cleared).

# ── LOCAL backend, fake user (default in __DEV__) ─────────────────────
# In __DEV__ builds, dev-auth is on by default — the app auto-signs-in
# via the backend's DEBUG-only `GET /dev/token`. The minted token is
# HMAC-signed for the SwaggerDevAuth account/device pair (defaults
# `1111…` / `2222…`, overridable in `backend/Nag.Api/.env.local`),
# so Swagger UI and the app share a tenant. No Clerk involvement.
NAG_API_BASE_URL=http://localhost:5266/
# EXPO_PUBLIC_NAG_DEV_AUTH=1   # default in __DEV__ — set to 0 to disable

# ── CLOUD apidev backend, real Clerk ──────────────────────────────────
# Uncomment to test against the cloud `apidev` deployment. The runtime
# equivalent is the dev menu's "Switch backend… → Cloud apidev — clerk"
# preset; either works.
# NAG_API_BASE_URL=https://apidev.<FILL_ME_IN>/
# EXPO_PUBLIC_NAG_DEV_AUTH=0
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_…
