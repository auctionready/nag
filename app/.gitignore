# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.ipa

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
# tsc composite build outputs (emitted alongside source files)
src/**/*.js
src/**/*.d.ts

# generated native folders
/ios
/android

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

.env.local
