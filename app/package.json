{
  "name": "@nag/app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --passWithNoTests --reporters=default --reporters=jest-junit",
    "test:ui": "maestro test .maestro/",
    "typecheck": "tsc --noEmit",
    "check:circular": "dpdm --no-warning --no-tree --exit-code circular:1 'src/**/*.{ts,tsx}'"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  },
  "jest-junit": {
    "outputDirectory": "./junit",
    "outputName": "results.xml"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/metro-runtime": "~55.0.11",
    "@nag/api-client": "workspace:*",
    "@nag/core": "workspace:*",
    "@nag/schema": "workspace:*",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/material-top-tabs": "^7.4.24",
    "@sentry/react-native": "^7.11.0",
    "date-fns": "catalog:",
    "drizzle-orm": "catalog:",
    "expo": "~55.0.26",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "^55.0.35",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "^55.0.16",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-hook-form": "^7.76.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-pager-view": "^8.0.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-tab-view": "^4.3.0"
  },
  "devDependencies": {
    "@sentry/cli": "3.4.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "dpdm": "^4.2.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "jest-junit": "^17.0.0",
    "typescript": "catalog:"
  },
  "private": true,
  "engines": {
    "node": ">=24"
  }
}
