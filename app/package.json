{
  "name": "@nag/app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --passWithNoTests --reporters=default --reporters=jest-junit",
    "test:ui": "maestro test .maestro/",
    "typecheck": "tsc --noEmit",
    "check:circular": "dpdm --no-warning --no-tree --exit-code circular:1 'src/**/*.{ts,tsx}'"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  },
  "jest-junit": {
    "outputDirectory": "./junit",
    "outputName": "results.xml"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/metro-runtime": "~56.0.11",
    "@nag/api-client": "workspace:*",
    "@nag/core": "workspace:*",
    "@nag/schema": "workspace:*",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@sentry/react-native": "^7.11.0",
    "date-fns": "catalog:",
    "drizzle-orm": "catalog:",
    "expo": "~56.0.3",
    "expo-auth-session": "~56.0.11",
    "expo-constants": "~56.0.14",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "^56.0.14",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.11",
    "expo-notifications": "~56.0.12",
    "expo-router": "~56.2.5",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.9",
    "expo-sqlite": "^56.0.4",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.76.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-pager-view": "^8.0.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-svg": "^15.15.4",
    "react-native-tab-view": "^4.3.0"
  },
  "devDependencies": {
    "@sentry/cli": "3.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "dpdm": "^4.2.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "jest-junit": "^17.0.0",
    "typescript": "~6.0.3"
  },
  "private": true,
  "engines": {
    "node": ">=24"
  }
}
